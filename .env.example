# Café Cloud — Local environment template
# Copy to .env and adjust values if needed.

SERVICE_NAME=cafe-cloud
ENVIRONMENT=local
LOG_LEVEL=INFO

# Optional API key for protected endpoints (e.g. notifier-service)
API_KEY=dev-secret-key

# PostgreSQL
POSTGRES_USER=cafe
POSTGRES_PASSWORD=cafe_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cafe_cloud

# RabbitMQ
RABBITMQ_USER=cafe
RABBITMQ_PASSWORD=cafe_secret
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# MongoDB
MONGO_USER=cafe
MONGO_PASSWORD=cafe_secret
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=cafe_cloud
